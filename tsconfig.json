{
    "$schema": "https://www.schemastore.org/tsconfig",
    "compilerOptions": {
        "lib": ["es2024"],
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "target": "esnext",
        "outDir": "dist",
        "types": ["node"],
        "baseUrl": ".",
        "paths": {
            "@/*": ["*"]
        },
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": ["**/*.ts", "**/*.js"],
    "exclude": ["node_modules", "build", "dist"]
}
