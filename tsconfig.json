{
    "$schema": "https://www.schemastore.org/tsconfig",
    "compilerOptions": {
        "lib": ["es2024"],
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "target": "esnext",
        "types": ["node"],
        "noEmit": true,
        "rootDir": ".",
        "allowImportingTsExtensions": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules", "build", "dist"]
}
